{
  "expo": {
    "name": "qr-app",
    "slug": "qr-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.kullaniciadin.articqr"
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": "QR kodları galeriye kaydetmek için izin istiyoruz."
        }
      ]
    ]
  }
}
